# =================================================================
# WINDMAR AI AGENT — Variables de entorno
# =================================================================
# Copia este archivo a .env.local y rellena los valores.
# .env.local NO se sube a Git (está en .gitignore).
# =================================================================

# ─────────────────────────────────────────────────────────────────
# NEXTAUTH (sesiones encriptadas)
# ─────────────────────────────────────────────────────────────────
# Genera con: npx auth secret
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────────
# MICROSOFT ENTRA ID — pedírselo a IT
# ─────────────────────────────────────────────────────────────────
# Application (client) ID — del App Registration en Azure
AUTH_MICROSOFT_ENTRA_ID_ID=

# Client secret VALUE (no el ID del secret, el VALUE) — del App Registration
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Tenant ID o URL completa del issuer
# Acepta solo el tenant ID (UUID) o https://login.microsoftonline.com/<TENANT_ID>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# ─────────────────────────────────────────────────────────────────
# SUPABASE (server-side — knowledge base + conversations)
# ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://psyfmkmlmvrijdxsirph.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────
# GROQ — motor de IA del chat
# ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ─────────────────────────────────────────────────────────────────
# ZOHO CRM — para el comando /cliente
# ─────────────────────────────────────────────────────────────────
# Self Client de Zoho con scopes:
#   ZohoCRM.modules.leads.READ
#   ZohoCRM.modules.deals.READ
#   ZohoCRM.users.READ
#
# Cómo generar el Self Client:
#   1) Ir a https://api-console.zoho.com
#   2) "Self Client" → "Generate Code"
#   3) Scopes: pegar los 3 de arriba (separados por comas)
#   4) Time Duration: 10 minutes
#   5) Copia el grant_code y úsalo en el comando curl de README-ZOHO.md
#   6) Obtienes refresh_token (largo, no expira)
#
# Ya tienes el Client ID/Secret aprobados en NOTAS-VENTAS-VASS — puedes
# reutilizarlos o generar un Self Client nuevo (recomendado: tokens
# independientes para que revocar uno no afecte al otro).
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=699641359
# Opcional — cambia si tu instancia de Zoho está en otro datacenter
# US: https://www.zohoapis.com (default)
# EU: https://www.zohoapis.eu
# IN: https://www.zohoapis.in
ZOHO_API_DOMAIN=https://www.zohoapis.com
